generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  imageUrl    String?
  isBundle    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            String   @id @default(uuid())
  customerName  String
  customerEmail String
  address       String
  city          String
  province      String
  postalCode    String
  totalAmount   Float
  status        String   @default("PENDING") // PENDING, PAID, SHIPPED
  items         String   // JSON string of item IDs and quantities
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
